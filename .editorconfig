# .editorconfig — flutter-monorepo
#
# Ensures consistent coding style across all editors and IDEs.
# See https://editorconfig.org

root = true

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# ---------------------------------------------------------------------------
# Dart — dart format enforces 2-space indent
# ---------------------------------------------------------------------------
[*.dart]
indent_size = 2

# ---------------------------------------------------------------------------
# YAML — pubspec.yaml, melos.yaml, workflow files
# ---------------------------------------------------------------------------
[*.{yml,yaml}]
indent_size = 2

# ---------------------------------------------------------------------------
# Markdown — preserve trailing whitespace (two spaces = line break)
# ---------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false

# ---------------------------------------------------------------------------
# Kotlin / Gradle (Android)
# ---------------------------------------------------------------------------
[*.{kt,kts,gradle}]
indent_size = 4

# ---------------------------------------------------------------------------
# Swift / Objective-C (iOS)
# ---------------------------------------------------------------------------
[*.{swift,m,h}]
indent_size = 4

# ---------------------------------------------------------------------------
# Makefiles — must use tabs
# ---------------------------------------------------------------------------
[Makefile]
indent_style = tab
